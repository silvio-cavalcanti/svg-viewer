{
  "name": "@open-cicd/svg-viewer",
  "version": "1.0.0",
  "description": "CLI tool to convert SVG to Base64 and open in browser",
  "type": "module",
  "main": "dist/cli.js",
  "bin": "svg-viewer ./bin/svg-viewer.js",
  "files": [
    "dist",
    "bin"
  ],
  "repository": "git@github.com:silvio-cavalcanti/svg-viewer.git",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "svg",
    "base64",
    "cli",
    "browser",
    "viewer"
  ],
  "author": "Silvio Cavalcanti",
  "license": "MIT",
  "bugs": "https://github.com/silvio-cavalcanti/svg-viewer/issues",
  "homepage": "https://github.com/silvio-cavalcanti/svg-viewer#readme",
  "dependencies": {
    "open": "10.1.0",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "@types/yargs": "17.0.32",
    "tsx": "4.16.0",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}